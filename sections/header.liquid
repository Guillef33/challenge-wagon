<header class="main-header container-i" id="main-header">
    <nav class="flex-i align-center justify-between main-nav w-100">
        
        <button class="mobile-menu-btn" aria-label="Toggle Menu" id="mobile-menu-btn">
            <svg class="icon-hamburger" width="30" height="30" viewBox="0 0 24 24" fill="none" stroke="var(--Bubble-Gum, #FFA9E7)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <line x1="3" y1="12" x2="21" y2="12"></line>
                <line x1="3" y1="6" x2="21" y2="6"></line>
                <line x1="3" y1="18" x2="21" y2="18"></line>
            </svg>
            <svg class="icon-close" style="display: none;" width="30" height="30" viewBox="0 0 24 24" fill="none" stroke="var(--Bubble-Gum, #FFA9E7)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <line x1="18" y1="6" x2="6" y2="18"></line>
                <line x1="6" y1="6" x2="18" y2="18"></line>
            </svg>
        </button>

        <a href="{{ routes.root_url }}" class="logo">
            {%- if section.settings.logo != blank -%}
                {{ section.settings.logo | image_url: width: 300 | image_tag: alt: section.settings.logo.alt, class: 'header__logo-img' }}
            {%- else -%}
                <span class="sp-i">{{ shop.name }}</span>
            {%- endif -%}
        </a>
        <div class="flex-i gap-ii">
            <ul class="nav-links flex-i align-center gap-ii">
                {%- for link in section.settings.menu.links -%}
                    <li class="sp-i">
                        <a href="{{ link.url }}" class="link-i">{{ link.title }}</a>
                    </li>
                {%- endfor -%}
            </ul>

            <div class="nav-icons flex-i gap-i">
                {%- if shop.customer_accounts_enabled -%}
                    <a href="{{ routes.account_url }}" aria-label="User Account">
                        {{ 'icon-account.svg' | inline_asset_content }}
                    </a>
                {%- endif -%}

                <a href="{{ routes.cart_url }}" class="cart-icon-wrapper" aria-label="Cart">
                    {{ 'icon-cart.svg' | inline_asset_content }}
                </a>
            </div>
        </div>
    </nav>

    <div class="mobile-menu-overlay" id="mobile-menu-overlay">
        <ul class="mobile-nav-links">
            {%- for link in section.settings.menu.links -%}
                <li>
                    <a href="{{ link.url }}" class="he-ii mobile-link-i" {% if forloop.first %}style="color: var(--Bubble-Gum, #FFA9E7);"{% endif %}>
                        {{ link.title }}
                    </a>
                </li>
            {%- endfor -%}
        </ul>
    </div>
</header>

<style>
  :root {
      --Bubble-Gum: #FFA9E7;
  }

  .main-header {
      background-color: #3973C6;
      position: fixed;
      top: 0;
      left: 50%;
      transform: translateX(-50%);
      color: var(--color-white);
      padding: 1vw 3vw;
      border-radius: 0 0 32px 32px;
      z-index: 99; 
  }

  .main-nav .logo img {
      max-width: 150px;
      display: block;
      height: auto;
  }

  .mobile-menu-btn {
      display: none;
      background: transparent;
      border: none;
      cursor: pointer;
      padding: 0;
  }

  ul.nav-links {
      list-style: none;
      padding: 0;
      margin: 0;
      text-transform: uppercase;
  }

  .nav-links .link-i {
      color: var(--color-white);
      font-size: 1.5vw;  {% comment %} Tuve que agregarlo, quedaba muy pequeno el size en desktop {% endcomment %}
  }

  .nav-links .link-i:after {
      background: var(--color-white);
  }

  .nav-icons {
      align-items: center;
      padding-right: 1vw;
  }

  .nav-icons a {
      position: relative;
      display: flex;
      align-items: center;
      justify-content: center;
      color: var(--color-white); 
  }

  .nav-icons svg {
    width: 2vw;
    height: 3vh;
  }

.mobile-menu-overlay {
    position: fixed;
    top: 60px; 
    left: 0;
    width: 100%;
    background-color: #3973C6;
    border-radius: 0 0 32px 32px;
    z-index: 999;
    padding: 20px 0;
    display: flex;
    justify-content: center;
    overflow: hidden;
    max-height: 0; 
    opacity: 0;
    transition: max-height 0.4s ease, opacity 0.3s ease;
}

.mobile-menu-overlay.is-open {
    max-height: 100vh;      
    opacity: 1;
}

  .mobile-nav-links {
      list-style: none;
      padding: 0;
      margin: 0;
      width: 80%; 
  }

  .mobile-nav-links li {
      border-bottom: 1px solid var(--Bubble-Gum, #FFA9E7);
      width: 100%;
      text-align: center;
  }

  .mobile-nav-links li:last-child {
      border-bottom: none; 
  }

  .mobile-link-i {
      color: var(--color-white);
      text-decoration: none;
      text-transform: uppercase;
      display: block;
      padding: 25px 0; 
  }

  @media (max-width: 991px) {
      .main-header {
          max-width: 100vw;
          padding: 3vw 5vw; 
          width: 100%;
      }
      
      .nav-links {
          display: none;
      }

    .nav-icons svg {
        width: 15px;
        height: 21px;
    }

      
      .mobile-menu-btn {
          display: flex;
          justify-content: flex-start;
      }
      
      .logo {
          flex: 1;
          display: flex;
          justify-content: center;
      }
      
      .main-nav .logo img {
          max-width: 120px;
      }
      
      .nav-icons {
          gap: 5vw;
          padding-right: 0;
      }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', function() {
      const menuBtn = document.getElementById('mobile-menu-btn');
      const mobileMenu = document.getElementById('mobile-menu-overlay');
      const iconHamburger = document.querySelector('.icon-hamburger');
      const iconClose = document.querySelector('.icon-close');

      menuBtn.addEventListener('click', function() {
          mobileMenu.classList.toggle('is-open');
          
          if (mobileMenu.classList.contains('is-open')) {
              iconHamburger.style.display = 'none';
              iconClose.style.display = 'block';
              document.body.style.overflow = 'hidden'; 
          } else {
              iconHamburger.style.display = 'block';
              iconClose.style.display = 'none';
              document.body.style.overflow = '';
          }
      });
  });
</script>

{% schema %}
{
  "name": "t:general.header",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Custom Logo"
    },
    {
      "type": "link_list",
      "id": "menu",
      "label": "t:labels.menu",
      "default": "main-menu"
    },
    {
      "type": "link_list",
      "id": "customer_account_menu",
      "label": "t:labels.customer_account_menu",
      "default": "customer-account-main-menu"
    }
  ]
}
{% endschema %}