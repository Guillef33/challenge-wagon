<section class="snack-promo">
    <div class="container-i flex-i align-center justify-between snack-promo-wrap">
        
        <div class="promo-text-col flex-i flex-column gap-i">
            <img src="{{ 'stress-free-snacking.png' | asset_url }}" alt="Stress Free Snacking" class="stamp" width="265" height="265">

            {%- if section.settings.title != blank -%}
                <div class="he-ii">
                    <h2 class="promo-title">{{ section.settings.title }}</h2>
                </div>
            {%- endif -%}

            <div class="sp-iii">
                <h5 class="desc desktop-only">
                    {{ section.settings.promo_text }}
                </h5>
                
                <h5 class="desc mobile-only">
                    {{ section.settings.promo_text_mobile | default: section.settings.promo_text }}
                </h5>
            </div>
        </div>

        <div class="collage-canvas">
            <img src="{{ 'card-orange.png' | asset_url }}" alt="Postal Naranja" class="item card-orange" width="800" height="600">
            <img src="{{ 'card-blue.png' | asset_url }}" alt="Postal Azul" class="item card-blue" width="800" height="600">
            <img src="{{ 'red-monster.png' | asset_url }}" alt="Monstruo Rojo" class="item red-monster" width="400" height="400">
            <img src="{{ 'card-green.png' | asset_url }}" alt="Postal Verde" class="item card-green" width="800" height="600">
            <img src="{{ 'crackers-stack.png' | asset_url }}" alt="Torre de Galletas" class="item crackers-stack" width="500" height="800">
            <img src="{{ 'black-monster.png' | asset_url }}" alt="Monstruo Negro" class="item black-monster" width="400" height="400">
        </div>

    </div> 

    <div class="marquee-strip">
        <div class="marquee-track sp-iii">
            <span>TAKE THE STRESS OUT OF SNACKING! - </span>
            <span>TAKE THE STRESS OUT OF SNACKING! - </span>
            <span>TAKE THE STRESS OUT OF SNACKING! - </span>
            <span>TAKE THE STRESS OUT OF SNACKING! - </span>
            <span>TAKE THE STRESS OUT OF SNACKING! - </span>
            <span>TAKE THE STRESS OUT OF SNACKING! - </span>
        </div>
    </div>
</section>

<style>
.snack-promo {
    background-color: #f6eedf;
    padding-top: 10vh;
    padding-bottom: 10vh;
    overflow: hidden;
    position: relative;
}

.promo-text-col {
    width: 20%;
    position: relative;
    margin-top: 30vh;
}

.stamp {
    max-width: 265px;
    z-index: 10;
    height: auto;
}

.promo-title {
    color: var(--color-primary);
    text-transform: uppercase;
    margin: 0;
    line-height: 1;
    display: none; 
}

.desc {
    color: var(--color-primary);
    text-transform: uppercase;
    margin: 0;
    max-width: 150px;
}

.collage-canvas {
    width: 80%;
    position: relative;
    aspect-ratio: 16 / 10;
    margin-top: 2%; 
}

.collage-canvas .item {
    position: absolute;
    height: auto;
}

.card-orange { width: 52%; top: 0%; left: -6%; transform: rotate(-2deg); z-index: 1; }
.card-blue { width: 57%; top: 6%; right: 20%; transform: rotate(2deg); z-index: 2; }
.card-green { width: 52%; bottom: 5%; left: 10%; transform: none; z-index: 4; }
.crackers-stack { width: 26%; bottom: 0%; right: 3%; z-index: 5; }
.black-monster { width: 10%; bottom: 48%; right: 7%; z-index: 6; }
.red-monster { width: 12%; top: 5%; right: 22%; z-index: 3; }

.marquee-strip  {
    display: none;
}

.mobile-only {
    display: none; 
}

.desktop-only {
    display: block; 
}

@media (max-width: 991px) {

    .desktop-only {
        display: none;
    }

    .mobile-only {
        display: block; 
    }
    
    .snack-promo {
        padding-bottom: 0;
        padding-top: 25%;
    }

    .snack-promo-wrap {
        flex-direction: column-reverse;
        gap: 2rem;
    }

    .promo-text-col,
    .collage-canvas {
        width: 100%;
        text-align: center;
        align-items: center;
    }

    .collage-canvas {
        aspect-ratio: 4 / 5; 
        margin-top: 15%; 
    }

    .promo-text-col {
        margin-top: 25%; 
    }

    .stamp {
        position: absolute;
        top: -70px; 
        left: -5%;
        max-width: 160px; 
    }

    .promo-title {
        display: block; 
        margin-top: 1.5rem;
        margin-bottom: 1.5rem;
        font-size: 15vw;  {% comment %} Tuve que agregarlo, quedaba muy pequeno el size en mobile {% endcomment %}
    }

    .desc {
        max-width: 90%;
        margin: 0 auto;
        font-size: 8vw;   {% comment %} Tuve que agregarlo, quedaba muy pequeno el size en mobile {% endcomment %}
    }

    .card-orange { top: 30%; left: -2%; width: 100%; transform: rotate(-4deg); }
    .card-blue { top: 18%; right: -5%; width: 100%; transform: rotate(2deg); z-index: 2; }
    .card-green { bottom: 30%; left: 5%; width: 90%; transform: rotate(0deg); z-index: 4; }
    .crackers-stack { bottom: -12%; right: -7%; width: 52%; z-index: 5; }
    .red-monster { top: -6%; right: 14%; width: 22%; z-index: 9; }
    .black-monster { bottom: -3%; right: 52%; width: 18%; z-index: 10; }

    .marquee-strip {
        background-image: url('{{ "marquee-background.png" | asset_url }}');
        background-repeat: no-repeat;
        background-size: cover;
        background-position: center;
        color: #1E429B; 
        padding: 20px 0;
        width: 100%;
        overflow: hidden;
        white-space: nowrap;
        margin-top: 8%; 
        display: block;
        height: 80px;
    }

    .marquee-strip::after {
        content: '';
        position: absolute;
        bottom: 0;
        left: 0;
        width: 100%;
        height: 20px; 
        background-color: #92C7EC;
        z-index: 0;
        bottom: -1px;
    }

    .marquee-track {
        display: inline-block;
        animation: scroll-marquee 15s linear infinite;
        text-transform: uppercase;
    }

    .marquee-track span {
        font-size: 6vw;
    }



    @keyframes scroll-marquee {
        0% { transform: translateX(0); }
        100% { transform: translateX(-50%); } 
    }
}
</style>

{% schema %}
{
  "name": "Snack Promo Collage",
  "tag": "section",
  "settings": [
    {
      "type": "textarea",
      "id": "title",
      "label": "Mobile Title",
      "default": "WELCOME TO SNACK PARADISE!"
    },
    {
      "type": "textarea",
      "id": "promo_text",
      "label": "Promotion Text",
      "default": "DELICIOUSLY CRISP. EXPERTLY BAKED CRACKERS—YOUR TICKET TO THE ULTIMATE SNACK PARADISE!"
    },
    {
    "type": "textarea",
    "id": "promo_text_mobile",
    "label": "Promotion Text (Mobile)",
    "default": "Delicious, Allergen-Friendly, and Functional Crackers for Joyful, Stress-Free Snacking"
}
  ],
  "presets": [
    {
      "name": "Snack Promo Collage",
      "category": "Custom Elements"
    }
  ]
}
{% endschema %}